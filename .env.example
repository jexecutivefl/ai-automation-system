# AI Automation Workflow System - Environment Variables

# OpenAI API Key (optional - mock mode works without it)
OPENAI_API_KEY=

# Classifier mode: "mock" or "openai"
# Set to "openai" and provide OPENAI_API_KEY for live AI classification
CLASSIFIER_MODE=mock

# SQLite database path
# Local default: ./data/automation.db
# On Vercel: automatically uses /tmp/automation.db (no config needed)
# DATABASE_PATH=./data/automation.db
